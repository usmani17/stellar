## 4. React Query Hooks

**Query keys:** `src/hooks/queries/queryKeys.ts` – add keys for new entities:

```ts
// Add to queryKeys object
myEntity: {
  all: ["myEntity"] as const,
  lists: () => [...queryKeys.myEntity.all, "list"] as const,
  detail: (id: number) => [...queryKeys.myEntity.all, "detail", id] as const,
},
```

**Query hook pattern:**
```ts
// src/hooks/queries/useMyEntity.ts
import { useQuery } from "@tanstack/react-query";
import { myEntityService } from "../../services/myEntity";
import { queryKeys } from "./queryKeys";

export const useMyEntity = (id: number | undefined, options?: { enabled?: boolean }) => {
  return useQuery({
    queryKey: queryKeys.myEntity.detail(id!),
    queryFn: () => myEntityService.getById(id!),
    enabled: (options?.enabled ?? true) && !!id,
    retry: (failureCount, error: any) => {
      if (error?.response?.status === 401 || error?.response?.status === 403) return false;
      return failureCount < 3;
    },
  });
};
```

**Mutation hook pattern:**
```ts
// src/hooks/mutations/useMyEntityMutations.ts
import { useMutation, useQueryClient } from "@tanstack/react-query";
import { myEntityService } from "../../services/myEntity";
import { queryKeys } from "../queries/queryKeys";

export const useCreateMyEntity = () => {
  const queryClient = useQueryClient();
  return useMutation({
    mutationFn: myEntityService.create,
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: queryKeys.myEntity.all });
    },
  });
};
```

